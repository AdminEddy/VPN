{
	"compilerOptions": {
		"noEmit": true,
		"module": "ESNext",
		"target": "ES2020",
		"lib": ["ES2022"],
		"checkJs": true,
		"allowJs": true,
		"strict": true,
		"alwaysStrict": true,
		"preserveConstEnums": true,
		"moduleResolution": "node",
		"sourceMap": true,
		"types": ["@cloudflare/workers-types"]
	},
	"include": ["src"],
	"exclude": ["node_modules", "dist", "test"]
}
